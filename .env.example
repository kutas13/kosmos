# Kopyala: .env.local (asla git'e ekleme)

# Supabase — Project Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co

# Önerilen: service_role JWT — sadece sunucuda, asla NEXT_PUBLIC yapma
SUPABASE_SERVICE_ROLE_KEY=
# Yeni format (sb_secret_...) — service_role yerine
SUPABASE_SECRET_KEY=

# Anon JWT veya publishable (sb_publishable_...)
SUPABASE_ANON_KEY=
SUPABASE_PUBLISHABLE_KEY=
