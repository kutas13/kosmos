# Kopyala: web/.env.local (asla git'e ekleme)

# Supabase — Project Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co

# Önerilen: service_role (Settings → API → service_role) — sadece sunucuda, asla NEXT_PUBLIC yapma
SUPABASE_SERVICE_ROLE_KEY=

# Alternatif: anon veya "publishable" key — supabase/migrations/001_musteriler.sql içindeki RLS policy gerekir
SUPABASE_ANON_KEY=
