# Supabase — Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co

# Sunucu tarafında kullanılır (Route Handlers). Repoya koyma.
# Önerilen: service_role (Settings → API → service_role secret)
SUPABASE_SERVICE_ROLE_KEY=

# Service role yoksa geçici olarak anon / publishable key (RLS politikası gerekir — supabase/migrations içine bakın)
SUPABASE_ANON_KEY=
